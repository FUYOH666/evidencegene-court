# EvidenceGene Court configuration (copy to .env; never commit .env)

# --- LLM (OpenAI-compatible endpoint) ---
# Local default: LM Studio. For judges with a cloud policy, point this at
# an Anthropic/OpenAI-compatible gateway and set the API key.
EGC_LLM_BASE_URL=http://localhost:1234/v1
EGC_LLM_MODEL=qwen3.6-35b-a3b-abliterated-heretic-mlx
EGC_LLM_API_KEY=not-needed-for-local
EGC_LLM_TIMEOUT=300
EGC_LLM_TEMPERATURE=0.2

# --- Forensic tool binaries (defaults work on SIFT and on macOS+brew) ---
EGC_VOL_CMD=vol
EGC_MMLS_CMD=mmls
EGC_FLS_CMD=fls
EGC_TOOL_TIMEOUT=900

# --- Court loop ---
EGC_MAX_ITERATIONS=6
EGC_PREVIEW_ROWS=20
